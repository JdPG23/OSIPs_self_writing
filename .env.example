# OSIP Self-Writing Configuration
# Copy this to .env and fill in your values

# --- OpenRouter (primary — one key for all LLMs) ---
OPENROUTER_API_KEY=sk-or-v1-...

# --- Model Selection (OpenRouter model IDs) ---
# OSIP_GENERATOR_MODEL=anthropic/claude-sonnet-4.6    # proposal writing
# OSIP_SCORER_MODEL=deepseek/deepseek-v3.2            # scoring (cheap + good)

# --- Embeddings ---
# OSIP_EMBEDDING_PROVIDER=huggingface                  # free, local (default)
# OSIP_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5          # 384 dims, runs on CPU
# OSIP_EMBEDDING_DIM=384

# --- Vector Store ---
# OSIP_VECTOR_STORE=chroma                             # "chroma" (local, default) or "supabase"
# OSIP_CHROMA_COLLECTION=osip_corpus
# OSIP_RAG_TOP_K=8

# --- Supabase (only if OSIP_VECTOR_STORE=supabase) ---
# SUPABASE_DB_URL=postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres

# --- Fallback: direct API keys (optional, if not using OpenRouter) ---
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
