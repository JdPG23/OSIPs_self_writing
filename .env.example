# OSIP Self-Writing Configuration
# Copy this to .env and fill in your values

# --- API Keys ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...          # Required for embeddings (text-embedding-3-small)

# --- Supabase ---
SUPABASE_DB_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# --- RAG Settings ---
# OSIP_COLLECTION_NAME=osip_corpus
# OSIP_EMBEDDING_PROVIDER=openai     # "openai" (needs OPENAI_API_KEY) or "huggingface" (free, local)
# OSIP_RAG_TOP_K=8                   # Number of chunks to retrieve per query

# --- Model Selection ---
# OSIP_API_PROVIDER=anthropic
# OSIP_GENERATOR_MODEL=claude-sonnet-4-20250514
# OSIP_SCORER_MODEL=claude-haiku-4-5-20251001
